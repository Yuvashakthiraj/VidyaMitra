# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Gemini API Keys
# Get these from Google AI Studio
# Main API key for general interview functionality
VITE_GEMINI_API_KEY=your_main_gemini_api_key_here

# Chatbot service API key (optional - falls back to main key if not specified)
VITE_GEMINI_CHATBOT_API_KEY=your_chatbot_gemini_api_key_here

# FRIEDE bot interview API key (optional - falls back to main key if not specified)
VITE_GEMINI_FRIEDE_API_KEY=your_friede_gemini_api_key_here

# Gemini Image Generation API Key (server-side only, for career roadmap images)
GEMINI_IMAGE_API_KEY=your_gemini_image_api_key_here

# OpenAI API Key (optional, for future use)
VITE_OPENAI_API_KEY=your_open_ai_api_key_here

# Groq API Key (server-side only, for Profile Analyzer AI roadmap generation)
# Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# GitHub API Token (optional, increases rate limits for Profile Analyzer)
# Get from https://github.com/settings/tokens
VITE_GITHUB_API_KEY=your_github_token_here

# YouTube API Key (optional, for video course recommendations)
# Get from https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here
# ==================== DATABASE CONFIGURATION ====================
# Database Type: 'sqlite', 'supabase', or 'dual' (writes to both during migration)
DB_TYPE=sqlite

# Supabase Configuration (Required only if DB_TYPE is 'supabase' or 'dual')
# Get these from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ==================== AWS CONFIGURATION ====================
# AWS credentials for S3 uploads and Lambda invocation
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# If using AWS Academy / Learner Lab, also add the session token:
AWS_SESSION_TOKEN=your_aws_session_token
AWS_REGION=us-east-1
S3_BUCKET_NAME=vidyamitra-uploads-629496

# ==================== AWS SES EMAIL ====================
# SES sender email — MUST be a verified identity in AWS SES.
# In SES sandbox mode: recipient emails must also be verified.
# Request production access to send to any email.
# Verify in: AWS Console → SES → Verified Identities → Create Identity
SES_FROM_EMAIL=no-reply@yourdomain.com

# ==================== AWS LAMBDA TEXTRACT ====================
# The public Function URL (or API Gateway URL) of your deployed textract-resume Lambda.
# Get this from: AWS Console → Lambda → your function → Configuration → Function URL
# Example: https://abcdefghij.lambda-url.us-east-1.on.aws/
AWS_LAMBDA_RESUME_API=https://your-lambda-function-url.lambda-url.us-east-1.on.aws/